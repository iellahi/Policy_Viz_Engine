# Ignore all data files (including .csv and .dta), but KEEP the master templates
/1_data/*
!/1_data/master_*.csv
/1_data/*.xlsx
/1_data/*.xls

# KEEP the spatial assets: public district boundaries + versioned name crosswalk
# (non-sensitive; needed by the choropleth template). Re-include the folder first,
# then its contents.
!/1_data/geo/
!/1_data/geo/**

# Ignore extra R files
/2_R/2.1_prep_leaps_data.R

# Ignore all generated outputs, but KEEP the .gitkeep file so the folder itself pushes
/4_output/*
!/4_output/.gitkeep

# Exclude specific external folders and zips
/ibraheem_viz_repo/
ibraheem_viz_repo.zip

# Standard R and System files to ignore
.Rproj.user/
.Rhistory
.RData
.DS_Store

# Knitted HTML never lives next to templates — output belongs in /4_output only
/3_templates/*.html
/3_templates_testing/*.html
README.html

# Stress suite (phase 4): generated corrupted data + its throwaway renders +
# the per-run results log never go to git. The scripts (stress_*.R) DO.
# stress_data is derived from the synthetic master_*.csv, but is treated like any
# other 1_data drop and kept out of the repo.
/5_tests/stress_data/
/5_tests/stress_output/
/5_tests/stress_results.csv

CLAUDE.md
PLAN.md